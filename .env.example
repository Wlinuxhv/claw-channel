# 生产环境必须修改为强随机字符串
# 生成方法：openssl rand -hex 32
JWT_SECRET=claw_channel_secret_key_change_in_production

# 服务端端口
SERVER_PORT=8080

# 管理员密码（生产环境必须修改）
ADMIN_PASSWORD=admin123

# 数据库路径
DATABASE_URL=sqlite:///data/claw.db

# OpenClaw WebSocket URL（如果使用外部 OpenClaw 实例）
# OPENCLAW_WS_URL=ws://openclaw:18789/ws

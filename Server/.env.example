# Claw Channel Server 环境变量示例

# 服务端监听端口
SERVER_PORT=8080

# JWT 密钥（生产环境必须修改为随机字符串）
# 生成方法：openssl rand -hex 32
JWT_SECRET=claw-channel-secret-key-change-in-production

# 数据库连接（SQLite）
DATABASE_URL=sqlite:///data/claw.db

# 管理员密码（生产环境必须修改）
ADMIN_PASSWORD=admin123

# ZeroTier 网络 ID（可选）
ZEROTIER_NETWORK_ID=
